# ── Session ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-with-openssl-rand-hex-32
SESSION_HOURS=8

# ── AI (optional) ─────────────────────────────────────────────────
# Leave AI_PROVIDER blank to disable the chat / AI-edit features.
AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5

# or Azure OpenAI:
# AI_PROVIDER=azure-openai
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── AI agent web research (optional) ──────────────────────────────
# Enables the agent's external research tools. When unset, agent mode
# has no internet access beyond the targeted `fetch_url` tool.
# AI_WEB_RESEARCH=true enables:
#   - `search_academic`     (OpenAlex — no key needed)
#   - `search_stackoverflow`(Stack Exchange — key optional)
# AI_WEB_RESEARCH=true
# Brave Search (adds `search_web`). Free tier: 2,000 queries/month.
# Register at https://api.search.brave.com
# BRAVE_API_KEY=
# Stack Exchange key — optional. Raises quota from 300 to 10,000 req/day.
# Register at https://stackapps.com/apps/oauth/register
# STACK_EXCHANGE_KEY=

# ── Auth ──────────────────────────────────────────────────────────
# OIDC (primary). Fill these to expose "Entrar com SSO" on /login.
# Any OIDC-compliant provider works: ZITADEL, Authentik, Keycloak,
# Google, Okta, Auth0, etc. Leave unset to only allow admin/LDAP.
# OIDC_CLIENT_SECRET is optional — omit for PKCE-only public clients.
# OIDC_ISSUER=https://zitadel.example.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_SCOPES="openid profile email"
# OIDC_ALLOWED_GROUPS=docs-users|docs-admins  # optional allowlist
# Pipe-separated list of claim paths to read user groups/roles from.
# Default covers the standard `groups` + `roles` claims (Keycloak, Okta,
# Authentik, Auth0). For ZITADEL, which emits roles at a URN-style claim:
#   OIDC_GROUPS_CLAIMS=groups|roles|urn:zitadel:iam:org:project:roles
# Array values are taken element-wise; object values use the keys.
# OIDC_GROUPS_CLAIMS=groups|roles

# Admin break-glass — always works. Set these so you can log in
# before your OIDC provider is configured (and if it breaks later).
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# LDAP (optional, enterprise AD deployments). Login form checks LDAP
# after the admin credentials. Leave unset to disable.
# LDAP_URL=ldaps://ldap.example.com:636
# LDAP_DOMAIN=example.com
# LDAP_BASE_DN=DC=example,DC=com
# LDAP_REQUIRED_OU=
# LDAP_REQUIRED_GROUP=
# LDAP_VERIFY_CERT=true

# ── Storage backend ───────────────────────────────────────────────
# local → reads/writes ./content; s3 → reads/writes a bucket (R2 compatible).
STORAGE=local
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto

# ── Branding ──────────────────────────────────────────────────────
# Displayed app name (page titles, back links, header).
BRAND_NAME=Docs
# Accent / primary color (any CSS-valid value). Quote it — # is a comment char.
BRAND_COLOR="#2563eb"
# Logo URL served by SvelteKit. Default: /api/branding/logo.svg (place file
# under content/branding/). Set to empty to disable and use text fallback.
# BRAND_LOGO_URL=/api/branding/logo.svg
# Inverted logo used in dark (tinta) theme. Optional — missing file falls
# back to BRAND_LOGO_URL. Upload content/branding/logo_negative.svg.
# BRAND_LOGO_NEGATIVE_URL=/api/branding/logo_negative.svg
# Company line in PDF cover footer. Defaults to BRAND_NAME if unset.
# BRAND_COMPANY="Acme Corporation · São Paulo, BR"

# ── Runtime ───────────────────────────────────────────────────────
DEBUG=false
ORIGIN=http://localhost:20000

# Serve our own robots.txt at /robots.txt. Default off so whatever the
# hosting layer serves (e.g. Cloudflare Managed Content) wins. Flip on
# if you need to pin the robots.txt content at the origin.
# TABULA_ROBOTS_TXT=true

# ─── Postgres ───────────────────────────────────────────────────────
# Workspace + role metadata. `docker compose up postgres` provides a
# local Postgres 18 at localhost:5432 (credentials below). For managed
# services (Neon, Supabase, RDS) set sslmode=require and the full DSN.
DATABASE_URL=postgres://tabula:tabula@localhost:5432/tabula?sslmode=disable

# ─── Platform admin (super-user) ─────────────────────────────────────
# Pipe-separated group identifiers. A user whose LDAP memberOf intersects
# PLATFORM_ADMIN_LDAP_GROUPS or whose OIDC `groups` claim intersects
# PLATFORM_ADMIN_OIDC_GROUPS becomes a platform admin — bypasses every
# workspace gate. The ADMIN_USER break-glass is always a platform admin
# regardless of these settings.
PLATFORM_ADMIN_LDAP_GROUPS=
PLATFORM_ADMIN_OIDC_GROUPS=
